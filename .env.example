OPENAI_PROXY_API_KEY=your_openai_compatible_proxy_key_here
OPENAI_PROXY_BASE_URL=https://api.openai-proxy.org/v1
OPENAI_PROXY_MODEL=gpt-4o-mini
PORT=4173

# 正式版账号与用户数据存储（MySQL）
# 方式一：完整连接串
# DATABASE_URL=mysql://wenjie_user:your_password@127.0.0.1:3306/wenjie
# 方式二：分项配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=wenjie_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=wenjie
MYSQL_TABLE_PREFIX=wj_
SESSION_TTL_DAYS=14

LINGXI_VIDEO_API_URL=
LINGXI_VIDEO_API_KEY=
VIDEO_PROVIDER=dashscope_wan
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_WORKSPACE_ID=your_workspace_id_here
DASHSCOPE_REGION=cn-beijing
DASHSCOPE_VIDEO_MODEL=wan2.5-t2v-preview
DASHSCOPE_VIDEO_RESOLUTION=480P
DASHSCOPE_VIDEO_DURATION=5
