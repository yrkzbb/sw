# 讯飞星火 HTTP API（API Password 在讯飞开放平台控制台获取）
XFYUN_SPARK_API_PASSWORD=your_xfyun_spark_api_password_here
XFYUN_SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1
XFYUN_SPARK_MODEL=4.0Ultra
PORT=4173

# 正式版账号与用户数据存储（MySQL）
# 方式一：完整连接串
# DATABASE_URL=mysql://wenjie_user:your_password@127.0.0.1:3306/wenjie
# 方式二：分项配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=wenjie_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=wenjie
MYSQL_TABLE_PREFIX=wj_
SESSION_TTL_DAYS=14

# 首个管理员账号（服务启动时若不存在会自动创建；若已存在会提升为 admin）
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-admin-password

LINGXI_VIDEO_API_URL=
LINGXI_VIDEO_API_KEY=
VIDEO_PROVIDER=dashscope_wan

# 讯飞星火智能 PPT（优先于 Felo PPT）
# 文档：https://www.xfyun.cn/doc/spark/PPTGeneration.html
XFYUN_PPT_APP_ID=your_xfyun_ppt_app_id_here
XFYUN_PPT_API_SECRET=your_xfyun_ppt_api_secret_here
XFYUN_PPT_BASE_URL=https://zwapi.xfyun.cn

# 科大讯飞 AI 虚拟人 Web API（VIDEO_PROVIDER=xunfei_virtual_human）
# 文档：https://s.apifox.cn/apidoc/docs-site/3774108/doc-3427395
# 文档：https://s.apifox.cn/apidoc/docs-site/3774108/doc-3427379
XUNFEI_VMS_APP_ID=your_xunfei_app_id_here
XUNFEI_VMS_API_KEY=your_xunfei_api_key_here
XUNFEI_VMS_API_SECRET=your_xunfei_api_secret_here
XUNFEI_VMS_HOST=vms.cn-huadong-1.xf-yun.com
XUNFEI_VMS_BASE_URL=https://vms.cn-huadong-1.xf-yun.com
XUNFEI_VMS_AVATAR_ID=118801001
XUNFEI_VMS_VCN=x3_qianxue
XUNFEI_VMS_STREAM_PROTOCOL=rtmp
XUNFEI_VMS_WIDTH=1280
XUNFEI_VMS_HEIGHT=720
XUNFEI_VMS_SPEED=50
XUNFEI_VMS_PITCH=50
XUNFEI_VMS_VOLUME=50

DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_WORKSPACE_ID=your_workspace_id_here
DASHSCOPE_REGION=cn-beijing
DASHSCOPE_VIDEO_MODEL=wan2.5-t2v-preview
DASHSCOPE_VIDEO_RESOLUTION=480P
DASHSCOPE_VIDEO_DURATION=5
