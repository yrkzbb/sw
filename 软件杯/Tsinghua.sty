\mode<presentation>

\newif\ifbeamer@secheader
\beamer@secheaderfalse

%\DeclareOptionBeamer{secheader}{\beamer@secheadertrue}
\ProcessOptionsBeamer

\useoutertheme[footline=authorinstitutetitle,subsection=false]{smoothbars}
\makeatletter % [add curpage/total page at the bottom](http://tex.stackexchange.com/questions/100838/beamer-dresden-theme-miniframes-appeareance-and-frame-number-insertion)
\newcommand{\frameofframes}{/}
\newcommand{\setframeofframes}[1]{\renewcommand{\frameofframes}{#1}}
\setbeamertemplate{footline} 
  {%
    \begin{beamercolorbox}[colsep=1.5pt]{upper separation line foot}
    \end{beamercolorbox}
    \begin{beamercolorbox}[ht=2.5ex,dp=1.125ex,%
      leftskip=.3cm,rightskip=.3cm plus1fil]{author in head/foot}%
      \leavevmode{\usebeamerfont{author in head/foot}\insertshortauthor}%
      \hfill%
      {\usebeamerfont{institute in head/foot}\usebeamercolor[fg]{institute in head/foot}\insertshortinstitute}%
    \end{beamercolorbox}%
    \begin{beamercolorbox}[ht=2.5ex,dp=1.125ex,%
      leftskip=.3cm,rightskip=.3cm plus1fil]{title in head/foot}%
      {\usebeamerfont{title in head/foot}\insertshorttitle}%
      \hfill%
      {\usebeamerfont{frame number}\usebeamercolor[fg]{frame number}\insertframenumber~\frameofframes~\inserttotalframenumber}
    \end{beamercolorbox}%
    \begin{beamercolorbox}[colsep=1.5pt]{lower separation line foot}
    \end{beamercolorbox}
  }
\makeatother

\useinnertheme{circles}

%\useoutertheme{default}
%\useinnertheme[shadow=true]{rounded}

% 设置主色为 #00688B (深湖蓝/深海蓝)
% RGB: 0, 104, 139 | 浮点数: 0, 0.408, 0.545
\xdefinecolor{maincolor}{rgb}{0, 0.408, 0.545}  % 主色 #00688B

% 设置各部分的颜色 - 主色较深，文字用白色
\setbeamercolor{footline}{bg=maincolor, fg=white}  % 页脚背景用新颜色，文字用白色
\setbeamercolor{frametitle}{bg=maincolor, fg=white} % 标题背景用新颜色，文字用白色
\setbeamercolor{title}{bg=maincolor, fg=white}      % 标题页背景用新颜色，文字用白色
\setbeamerfont{frametitle}{size=\large}
%\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{bibliography item}[text]
\setbeamertemplate{caption}[numbered]

% 调色板设置 - 适配新颜色
\setbeamercolor{palette primary}{use=structure,fg=white,bg=maincolor}
\setbeamercolor{palette secondary}{use=structure,fg=white,bg=maincolor!75!black}
\setbeamercolor{palette tertiary}{use=structure,fg=white,bg=maincolor!50!black}
\setbeamercolor{palette quaternary}{fg=white,bg=maincolor!50!black}
%\setbeamercolor*{sidebar}{use=structure,bg=structure.fg}
\setbeamercolor{titlelike}{parent=palette primary}

%% 块设置
\setbeamercolor{block title}{bg=maincolor, fg=white}      % 块标题用新背景和白色文字
\setbeamercolor{block body}{bg=maincolor!10!white, fg=black} % 块内容用极浅的背景(10%主色)和黑色文字
\setbeamercolor*{block title example}{use={normal text,example text},bg=white,fg=maincolor} % 示例块标题
\setbeamercolor{fine separation line}{}
\setbeamercolor{item projected}{fg=white, bg=maincolor}
\setbeamercolor{palette sidebar primary}{use=normal text,fg=normal text.fg}
\setbeamercolor{palette sidebar quaternary}{use=structure,fg=structure.fg}
\setbeamercolor{palette sidebar secondary}{use=structure,fg=structure.fg}
\setbeamercolor{palette sidebar tertiary}{use=normal text,fg=normal text.fg}
%\setbeamercolor{palette sidebar quaternary}{fg=white}
\setbeamercolor{section in sidebar}{fg=maincolor}
\setbeamercolor{section in sidebar shaded}{fg=maincolor!50}
\setbeamercolor{separation line}{}
\setbeamercolor{sidebar}{bg=maincolor}
\setbeamercolor{sidebar}{parent=palette primary}
\setbeamercolor{structure}{fg=maincolor}  % 结构元素（如 bullets）用新颜色
\setbeamercolor{subsection in sidebar}{fg=maincolor}
\setbeamercolor{subsection in sidebar shaded}{fg=maincolor!50}
\AtBeginSection[]{
	\begin{frame}
		\tableofcontents[sectionstyle=show/shaded,subsectionstyle=show/shaded/hide,subsubsectionstyle=show/shaded/hide]
	\end{frame}
}
\AtBeginSubsection[]{
	\begin{frame}
		\tableofcontents[sectionstyle=show/shaded,subsectionstyle=show/shaded/hide,subsubsectionstyle=show/shaded/hide]
	\end{frame}
}

\mode
<all>